{
  "extends": "solhint:recommended",
  "plugins": ["prettier"],
  "rules": {
    "prettier/prettier": "error",
    "compiler-version": ["error", ">=0.4.0"],
    "func-visibility": ["error", { "ignoreConstructors": true }],
    "no-empty-blocks": "off",
    "constructor-syntax": "off",
    "not-rely-on-time": "off",
    "reason-string": "off",
    "quotes": "off",
    "custom-errors": "off"
  }
}
